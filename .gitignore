.pnpm-store/
.yarn/
.yarn-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Frontend build outputs
dist/
build/
coverage/
.vite/
.cache/
.tmp/
temp/
tmp/

# Tauri / Rust build outputs
target/
**/target/

# Rust temporary files
*.rs.bk

# Environment files
.env
.env.*
!.env.example

# Logs
logs/
*.log

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Windows shortcuts / temp
*.lnk
*.tmp
*.temp

# IDE / Editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# TypeScript
*.tsbuildinfo

# Tauri generated mobile/build artifacts
apps/desktop/src-tauri/gen/android/.gradle/
apps/desktop/src-tauri/gen/android/build/
apps/desktop/src-tauri/gen/android/app/build/
apps/desktop/src-tauri/gen/apple/build/

# Certificates / signing / secrets
*.p12
*.pfx
*.key
*.pem
*.crt
*.cer
*.mobileprovision
*.keystore
*.jks
*.asc
*.sig

# Local app data / test data
.local/
data/
storage/
sessions/
logs/

